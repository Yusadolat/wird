{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "internal": {
      "distribution": "internal",
      "android": {
        "buildType": "app-bundle"
      },
      "channel": "internal"
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "channel": "production"
    }
  },
  "submit": {
    "internal": {},
    "production": {
      "android": {
        "track": "open"
      }
    }
  }
}
