{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_OAUTH_REDIRECT_SCHEME": "wird",
        "EXPO_PUBLIC_OAUTH_REDIRECT_URI": "wird://auth/callback",
        "SENTRY_ORG": "prontoville",
        "SENTRY_PROJECT": "wird"
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "preview"
    },
    "internal": {
      "distribution": "internal",
      "env": {
        "SENTRY_ORG": "prontoville",
        "SENTRY_PROJECT": "wird"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "channel": "internal"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "SENTRY_ORG": "prontoville",
        "SENTRY_PROJECT": "wird"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "channel": "production"
    }
  },
  "submit": {
    "internal": {},
    "production": {
      "android": {
        "track": "open"
      }
    }
  }
}
